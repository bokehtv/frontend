# Frontend Environment Variables

# Next.js Public Environment Variables
# These variables will be embedded into the browser build.

# API Base URL
# This points to the Express.js backend.
# Local Development (default fallback if omitted): http://localhost:5000/api/v1
# Production (Railway): https://[YOUR-RAILWAY-DOMAIN].up.railway.app/api/v1
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
